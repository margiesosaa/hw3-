<h1><%= @place.name %></h1>

<% @entries.each do |entry| %>
  <div>
    <h3><%= entry.title %></h3>
    <p><%= entry.occurred_on %></p>
    <p><%= entry.description %></p>
  </div>
<% end %>
<br>
<br>
<a href="/entries/new?place_id=<%= @place.id %>">New Post</a>

